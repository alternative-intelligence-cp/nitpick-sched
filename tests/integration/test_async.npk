use "../../src/context/coroutine.npk".*;
use "../../src/structs/tcb.npk".*;
use "../../src/structs/context.npk".*;
use "../../src/structs/memory_helpers.npk".*;

pub func:proc_exit = int32(int32: code) {
    int32: dummy = asm!!!<int32>("x86_64", "movl $1, %edi; movl $$60, %eax; syscall", "=r,r", code);
    pass(0i64);
};

pub func:main = int32() {
    TCB->: t = calloc(1i64, 1024i64) => TCB->;
    t->ctx.vruntime = 0i64.0fix256;
    
    int64: mock_frame = 0xDEADBEEF;
    drop await_suspend(t, mock_frame);
    
    if (t->coro_frame_ptr != mock_frame) {
        drop proc_exit(11i64);
    }
    
    bool: res = raw await_resume(t);
    if (!res) {
        drop proc_exit(13i64);
    }
    
    exit 0i64;
};

func:failsafe = int32(tbb32:err) { exit 99i64; };
