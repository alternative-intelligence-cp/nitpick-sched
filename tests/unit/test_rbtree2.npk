use "../../src/fairness/rbtree.npk".*;
use "../../src/structs/memory_helpers.npk".*;

pub func:proc_exit = int32(int32: code) {
    int32: dummy = asm!!!<int32>("x86_64", "movl $1, %edi; movl $$60, %eax; syscall", "=r,r", code);
    pass(0i64);
};

pub func:main = int32() {
    RBTree->: tree = raw rbt_init(128i64);
    if (tree == NULL) { exit 101i64; }
    
    int32: n1 = raw rbt_alloc(tree);
    if (n1 == -1i64) { exit 102i64; }
    drop set_vruntime(tree, n1, 500i64);
    drop set_pid(tree, n1, 10i64);
    drop set_tcb(tree, n1, 100i64);
    
    int32: x = raw get_root(tree);
    if (x == -1i64) {
        drop set_root(tree, n1);
    } else {
        exit 103i64;
    }
    
    drop rbt_insert_fixup_safe(tree, n1);
    
    exit 200i64;
};

func:failsafe = int32(tbb32:err) {
    exit 99i64;
};
