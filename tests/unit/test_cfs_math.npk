use "../../src/fairness/cfs_math.npk".*;

pub func:proc_exit = int32(int32: code) {
    int32: dummy = asm!!!<int32>("x86_64", "movl $1, %edi; movl $$60, %eax; syscall", "=r,r", code);
    pass(0i64);
};

pub func:main = int32() {
    // 1i64. Test calc_vruntime_delta
    // delta = 10i64.0fix256, weight = 1024i64.0fix256 (NICE 0i64) -> delta = 10i64.0fix256 * 1024i64 / 1024i64 = 10i64.0fix256
    fix256: d1_exec = 10i64.0fix256;
    fix256: w1 = 1024i64.0fix256;
    fix256: d1 = raw calc_vruntime_delta(d1_exec, w1);
    
    fix256: e1 = 10i64.0fix256;
    if (d1 != e1) { exit 1i64; }
    
    // delta = 10i64.0fix256, weight = 2048i64.0fix256 -> delta = 10i64.0fix256 * 1024i64 / 2048i64 = 5i64.0fix256
    fix256: w2 = 2048i64.0fix256;
    fix256: d2 = raw calc_vruntime_delta(d1_exec, w2);
    
    fix256: e2 = 5i64.0fix256;
    if (d2 != e2) { exit 2i64; }
    
    // 2i64. Test calc_ideal_runtime
    fix256: target = 6i64.0fix256;
    fix256: min_gran = 0i64.75fix256;
    
    fix256: tw1 = 3000i64.0fix256;
    fix256: rw1 = 1000i64.0fix256;
    // total = 3000i64, weight = 1000i64 -> ideal = 6i64.0fix256 * (1000i64/3000i64) = 2i64.0fix256
    fix256: i1 = raw calc_ideal_runtime(target, min_gran, rw1, tw1);
    
    fix256: e3 = 2i64.0fix256;
    if (i1 != e3) { exit 3i64; }
    
    // total = 30000i64, weight = 1000i64 -> ideal = 6i64.0fix256 * (1000i64/30000i64) = 0i64.2fix256
    // BUT min_gran = 0i64.75fix256, so should clamp to 0i64.75fix256
    fix256: tw2 = 30000i64.0fix256;
    fix256: i2 = raw calc_ideal_runtime(target, min_gran, rw1, tw2);
    
    fix256: e4 = 0i64.75fix256;
    if (i2 != e4) { exit 4i64; }
    
    exit 0i64;
};

func:failsafe = int32(tbb32:err) {
    exit 99i64;
};
