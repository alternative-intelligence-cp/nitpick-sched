pub func:ptr_add = int64(any->: base, int64: offset) {
    pass asm!!!<int64>("x86_64", "movq $1, $0\naddq $2, $0", "=r,r,r", base, offset);
};
pub func:read_int64 = int64(int64: ptr) {
    pass asm!!!<int64>("x86_64", "movq ($1), $0", "=r,r", ptr);
};
pub func:write_int64 = int32(int64: ptr, int64: val) {
    pass asm!!!<int32>("x86_64", "movq $2, ($1)", "=r,r,r", ptr, val);
};

pub struct:ArenaSlot = { int64: item; int64: next_free; };

pub func:main = int32() {
    ArenaSlot->: slots = calloc(10i64, 16i64) => ArenaSlot->;
    int64: base = raw ptr_add(slots => any->, 0i64);
    
    // slots[2i64].next_free = 42i64
    int64: p2 = base + (2i64 * 16i64) + 8i64;
    int32: ok1 = raw write_int64(p2, 42i64);
    
    // int64 out = slots[2i64].next_free
    int64: out = raw read_int64(p2);
    
    if (out != 42i64) { exit 1i64; }
    exit 0i64;
};
pub func:failsafe = int32(tbb32:err) { exit 99i64; };
