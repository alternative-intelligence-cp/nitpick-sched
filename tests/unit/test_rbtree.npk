use "../../src/fairness/rbtree.npk".*;
use "../../src/structs/memory_helpers.npk".*;

pub func:proc_exit = int32(int32: code) {
    int32: dummy = asm!!!<int32>("x86_64", "movl $1, %edi; movl $$60, %eax; syscall", "=r,r", code);
    pass(0i64);
};

pub func:main = int32() {
    RBTree->: tree = raw rbt_init(128i64);
    if (tree == NULL) { exit 1i64; }
    
    // Insert tasks: vruntime, pid, handle
    int32: n1 = raw rbt_insert(tree, 500i64, 10i64, 100i64);
    int32: n2 = raw rbt_insert(tree, 300i64, 11i64, 101i64);
    int32: n3 = raw rbt_insert(tree, 800i64, 12i64, 102i64);
    int32: n4 = raw rbt_insert(tree, 300i64, 9i64,  103i64); // Tie break pid 9i64 < 11i64
    
    // Extract min should be strictly O(1i64) since we read leftmost cache
    int32: min_node = raw rbt_peek_min(tree);
    if (min_node == -1i64) { exit 2i64; }
    
    // The lowest vruntime is 300i64. There's PID 9i64 and 11i64.
    // PID 9i64 is smaller than 11i64, so n4 should be leftmost.
    if (min_node != n4) { exit 3i64; }
    
    int32: h1 = raw rbt_extract_min(tree);
    if (h1 != 103i64) { exit 4i64; } // handle 103i64
    
    // Next min should be n2 (vruntime 300i64, pid 11i64)
    min_node = raw rbt_peek_min(tree);
    if (min_node != n2) { exit 5i64; }
    
    int32: h2 = raw rbt_extract_min(tree);
    if (h2 != 101i64) { exit 6i64; }
    
    // Next min should be n1 (vruntime 500i64)
    int32: h3 = raw rbt_extract_min(tree);
    if (h3 != 100i64) { exit 7i64; }
    
    // Next min should be n3 (vruntime 800i64)
    int32: h4 = raw rbt_extract_min(tree);
    if (h4 != 102i64) { exit 8i64; }
    
    // Tree should be empty
    if (raw rbt_peek_min(tree) != -1i64) { exit 9i64; }
    if (raw rbt_extract_min(tree) != -1i64) { exit 10i64; }

    exit 0i64;
};

func:failsafe = int32(tbb32:err) {
    exit 99i64;
};
