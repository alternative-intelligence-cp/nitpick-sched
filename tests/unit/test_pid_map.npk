// test_pid_map.npk
use "../../src/structs/pid_map.npk".{PidMap, pid_map_init, pid_map_insert, pid_map_lookup, pid_map_remove};

func:main = int32() {
    IdxHandle<TCB>: h1;
    h1.index = 5i64;
    h1.generation = 1i64;
    
    IdxHandle<TCB>: h2;
    h2.index = 42i64;
    h2.generation = 2i64;

    PidMap: map;
    map.capacity = 1024i64;
    drop pid_map_init(@map);
    
    if (map.slots[100i64].occupied) {
        exit 128i64; // Exits with 128i64 if it's true after init!
    }
    
    int32: ok1 = raw pid_map_insert(@map, 100i64, @h1);
    if (ok1 != 0i64) { exit ok1; } // Exit with ok1
    
    
    int32: ok2 = raw pid_map_insert(@map, 200i64, @h2);
    if (ok2 != 0i64) { exit ok2; }
    
    // Test Lookup
    IdxHandle<TCB>: l1 = raw pid_map_lookup(@map, 100i64);
    if (l1.index != 5i64) { exit 3i64; }
    if (l1.generation != 1i64) { exit 4i64; }
    
    IdxHandle<TCB>: l2 = raw pid_map_lookup(@map, 200i64);
    if (l2.index != 42i64) { exit 5i64; }
    
    // Test Lookup Non-existent
    IdxHandle<TCB>: l3 = raw pid_map_lookup(@map, 300i64);
    if (l3.index != -1i64) { exit 6i64; }
    
    // Test Remove
    bool: rm1 = raw pid_map_remove(@map, 100i64);
    if (!rm1) { exit 7i64; }
    
    IdxHandle<TCB>: l4 = raw pid_map_lookup(@map, 100i64);
    if (l4.index != -1i64) { exit 8i64; }
    
    // Verify remaining
    IdxHandle<TCB>: l5 = raw pid_map_lookup(@map, 200i64);
    if (l5.index != 42i64) { exit 9i64; }
    
    exit 0i64;
};

func:failsafe = int32(tbb32:err) {
    exit 99i64;
};
