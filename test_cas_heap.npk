use "src/structs/memory_helpers.npk".*;

pub func:cmpxchg_int64 = bool(int64: ptr, int64: expected, int64: desired) {
    int32: success = asm!!!<int32>("x86_64", "lock cmpxchgq $3, ($1); setz %al; movzbl %al, $0", "=r,r,{rax},r", ptr, expected, desired);
    if (success == 0) { pass false; }
    pass true;
};

pub func:proc_exit = int32(int32: code) {
    int32: dummy = asm!!!<int32>("x86_64", "movl $1, %edi; movl $$60, %eax; syscall", "=r,r", code);
    pass 0;
};

pub func:main = int32() {
    int64: ptr = raw ptr_to_int(calloc(1, 8) => any->);
    drop raw write_int64(ptr, 100);
    
    bool: s1 = raw cmpxchg_int64(ptr, 50, 200); // Should fail
    if (s1) { exit 1; }
    
    bool: s2 = raw cmpxchg_int64(ptr, 100, 200); // Should succeed
    if (!s2) { exit 2; }
    
    int64: val = raw read_int64(ptr);
    if (val != 200) { exit 3; }
    
    exit 0;
};
func:failsafe = int32(tbb32:err) { exit 99; };
