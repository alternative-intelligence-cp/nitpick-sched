// context.npk — Scheduling Context definition

pub struct:TaskContext = {
    fix256: vruntime;
    fix256: budget;
    fix256: period;
    int32: nice_value;
    atomic<int32>: state;
};

// Minimal struct representing the LLVM coroutine frame pointer state
pub struct:CoroutineContext = {
    int64: frame_ptr;
    bool: is_done;
};
